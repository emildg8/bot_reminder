BOT_TOKEN=your_telegram_bot_token

DATABASE_URL=sqlite+aiosqlite:///./data/reminders.db

# Free LLM (хотя бы один ключ рекомендуется)
GROQ_API_KEY=
GEMINI_API_KEY=

# Paid LLM (опционально, fallback)
OPENAI_API_KEY=

# STT
WHISPER_MODEL=tiny
WHISPER_DEVICE=cpu
USE_YANDEX_STT=false
YANDEX_API_KEY=
YANDEX_FOLDER_ID=

# Defaults
DEFAULT_TIMEZONE=Europe/Moscow

# Logs: data/logs/bot.log, ротация ~6 MB (2 MB × 3 файла)
LOG_MAX_BYTES=2097152
LOG_BACKUP_COUNT=2

# DB backup: data/backups/, keep last N files
DB_BACKUP_KEEP=7
DB_BACKUP_INTERVAL_HOURS=24

# Admin (опционально): один id или несколько через запятую
# ADMIN_TELEGRAM_IDS=250891839
# ADMIN_TELEGRAM_IDS=111111111,222222222
ADMIN_TELEGRAM_IDS=
