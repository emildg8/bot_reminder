BOT_TOKEN=your_telegram_bot_token

DATABASE_URL=sqlite+aiosqlite:///./data/reminders.db

# Free LLM (хотя бы один ключ рекомендуется)
GROQ_API_KEY=
GEMINI_API_KEY=

# Paid LLM (опционально, fallback)
OPENAI_API_KEY=

# STT (голос и кружочки)
WHISPER_MODEL=tiny
WHISPER_DEVICE=cpu
GROQ_WHISPER_MODEL=whisper-large-v3-turbo
USE_YANDEX_STT=false
YANDEX_API_KEY=
YANDEX_FOLDER_ID=

# Defaults
DEFAULT_TIMEZONE=Europe/Moscow

# Logs: data/logs/bot.log, ротация ~6 MB (2 MB × 3 файла)
LOG_MAX_BYTES=2097152
LOG_BACKUP_COUNT=2

# DB backup: data/backups/, keep last N files
DB_BACKUP_KEEP=7
DB_BACKUP_INTERVAL_HOURS=24

# Admin (опционально): один id или несколько через запятую
# ADMIN_TELEGRAM_IDS=250891839
ADMIN_TELEGRAM_IDS=

# Auto-update (fallback если нет Wisp API в GitHub Actions)
AUTO_UPDATE_ENABLED=true
AUTO_UPDATE_INTERVAL_MINUTES=1
GITHUB_REPO=emildg8/bot_reminder
GITHUB_BRANCH=main
