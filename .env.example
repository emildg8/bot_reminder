# =============================================================================
# bot_reminder — переменные окружения
# Скопируй: cp .env.example .env
# =============================================================================

# --- Обязательно ---
BOT_TOKEN=your_telegram_bot_token

# --- База данных ---
# SQLite (по умолчанию, один процесс):
DATABASE_URL=sqlite+aiosqlite:///./data/reminders.db
# PostgreSQL (multi-instance, docker compose --profile postgres):
# DATABASE_URL=postgresql+asyncpg://reminder:reminder@db:5432/reminder

# --- LLM (парсинг фраз; хотя бы один ключ рекомендуется) ---
GROQ_API_KEY=
GEMINI_API_KEY=
OPENAI_API_KEY=

# --- STT (голос и кружочки) ---
# С GROQ_API_KEY голос работает через облако без ffmpeg
# LOCAL_WHISPER_ENABLED=true — fallback на CPU (тяжёлый, не для Wispbyte)
LOCAL_WHISPER_ENABLED=false
WHISPER_MODEL=tiny
WHISPER_DEVICE=cpu
GROQ_WHISPER_MODEL=whisper-large-v3-turbo
USE_YANDEX_STT=false
YANDEX_API_KEY=
YANDEX_FOLDER_ID=

# --- Часовой пояс по умолчанию ---
DEFAULT_TIMEZONE=Europe/Moscow

# --- Логи (data/logs/bot.log, ротация) ---
LOG_MAX_BYTES=2097152
LOG_BACKUP_COUNT=2

# --- Бэкап БД (data/backups/) ---
DB_BACKUP_KEEP=7
DB_BACKUP_INTERVAL_HOURS=24

# --- Админы бота (/health, /update, /sysinfo) ---
# Один id или несколько через запятую
# Встроенный admin 292396648 всегда в списке
ADMIN_TELEGRAM_IDS=

# --- Благодарность автору Stars (выключено по умолчанию) ---
STARS_TIPS_ENABLED=false
STARS_TIP_PRESETS=50,100,250
STARS_TIPS_NOTIFY_ADMIN=true

# --- Auto-update с GitHub (fallback без Wisp API в CI) ---
AUTO_UPDATE_ENABLED=true
AUTO_UPDATE_INTERVAL_MINUTES=1
GITHUB_REPO=emildg8/bot_reminder
GITHUB_BRANCH=main
