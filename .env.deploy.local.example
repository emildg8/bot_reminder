# Скопируй в .env.deploy.local (файл в .gitignore) и запусти setup:

#   Windows:  .\scripts\setup_github_deploy.ps1
#   Linux:    bash scripts/setup_github_deploy.sh

# --- Обязательно для CI deploy ---

# Токен бота из BotFather (тот же, что на Wispbyte)
BOT_TOKEN=

# Telegram user id админа (через @userinfobot)
# Можно несколько: 123456,789012
ADMIN_TELEGRAM_IDS=

# --- Wispbyte API (instant restart после push) ---

WISP_PANEL_URL=https://panel.wispbyte.com
WISP_API_TOKEN=
WISP_SERVER_UUID=

# Альтернатива (Pterodactyl):
# PTERODACTYL_PANEL_URL=
# PTERODACTYL_API_TOKEN=
# PTERODACTYL_SERVER_UUID=
