# Скопируй в .env.deploy.local (файл в .gitignore) и запусти:
#   Windows: .\scripts\setup_github_deploy.ps1
#   Linux/macOS: bash scripts/setup_github_deploy.sh

# Токен @break_remind_bot из BotFather (тот же, что на Wispbyte)
BOT_TOKEN=

# Telegram user id админа (можно один: 250891839)
ADMIN_TELEGRAM_IDS=

# Wispbyte Client API — Account → Security → API Tokens
WISP_PANEL_URL=https://panel.wispbyte.com
WISP_API_TOKEN=
WISP_SERVER_UUID=
